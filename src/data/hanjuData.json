// 推演提取性格、风格与脸谱 
export function getRoleCharacteristics(roleType) {
    const traits = { charTrait: "依据具体剧情与行当而定", actStyle: "汉剧传统程式化表演", makeup: "传统汉剧行当扮相" };
    if (!roleType) return traits;
    if (roleType.includes('末') || roleType.includes('生') || roleType.includes('老生')) {
        traits.charTrait = "稳重老成，正派忠厚"; traits.actStyle = "唱念并重，气度沉稳，身段严谨"; traits.makeup = "多戴髯口（胡须），素面俊扮";
    } else if (roleType.includes('净') || roleType.includes('大花脸')) {
        traits.charTrait = "性格刚烈、鲁莽或权诈"; traits.actStyle = "动作大开大合，嗓音洪亮粗犷"; traits.makeup = "勾画复杂脸谱，重彩油彩";
    } else if (roleType.includes('四旦') || roleType.includes('青衣') || roleType.includes('正旦')) {
        traits.charTrait = "端庄娴淑，温婉坚韧"; traits.actStyle = "注重唱功与委婉细腻的身段"; traits.makeup = "梳大头贴片子，素雅淡妆";
    } else if (roleType.includes('丑')) {
        traits.charTrait = "滑稽机智，幽默或市侩"; traits.actStyle = "语言诙谐，动作轻巧灵活"; traits.makeup = "鼻梁勾画白粉块，俗称“豆腐块”";
    } else if (roleType.includes('外')) {
        traits.charTrait = "苍老稳健，多为长者与清客"; traits.actStyle = "以做工和苍老念白见长"; traits.makeup = "戴白须，服饰偏素净";
    } else if (roleType.includes('小生') || roleType.includes('七小')) {
        traits.charTrait = "风流倜傥，儒雅俊秀"; traits.actStyle = "用小嗓（假声）演唱，折扇表演"; traits.makeup = "俊扮，不戴须（白面）";
    } else if (roleType.includes('贴') || roleType.includes('花旦')) {
        traits.charTrait = "活泼开朗，泼辣伶俐"; traits.actStyle = "重做工与念白，眼神身段灵动"; traits.makeup = "发饰俏丽，色彩鲜艳";
    } else if (roleType.includes('夫') || roleType.includes('老旦')) {
        traits.charTrait = "慈祥稳重，或严厉威严"; traits.actStyle = "本嗓高亢演唱，步履蹒跚"; traits.makeup = "不贴片子，多持拐杖，老态妆";
    } else if (roleType.includes('杂') || roleType.includes('副净')) {
        traits.charTrait = "粗犷勇猛，性格张扬鲜明"; traits.actStyle = "重身段架子与武打翻跌"; traits.makeup = "勾画碎脸或二花脸";
    }
    return traits;
}

// 推演人际关系
export function inferRelationship(roleA, roleB) {
    const r1 = roleA || '';
    const r2 = roleB || '';
    if (r1.includes('老旦') || r2.includes('老旦')) return '长辈/母亲';
    if (r1.includes('外') || r2.includes('外')) return '长辈/君王';
    if ((r1.includes('生') && r2.includes('旦')) || (r1.includes('旦') && r2.includes('生'))) return '夫妻/情侣';
    if ((r1.includes('净') && r2.includes('生')) || (r1.includes('杂') && r2.includes('生'))) return '对手/君臣';
    if (r1.includes('丑') || r2.includes('丑')) return '主仆/同盟';
    if ((r1.includes('净') && r2.includes('净')) || (r1.includes('杂') && r2.includes('杂'))) return '强敌/结义兄弟';
    if (r1.includes('生') && r2.includes('生')) return '同僚/挚友/父子';
    return '同行/故交';
}